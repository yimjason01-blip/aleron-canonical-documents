{
  "$schema": "./schemas/components.schema.json",
  "design_system": "aleron-md-product-ds",
  "version": "0.4.0",
  "updated": "2026-07-16",
  "status_note": "Ratified entries have complete reusable web implementations. Provisional entries declare the intended state contract and may not yet encode every state selector. The physician register and the air and copy laws remain provisional where marked.",
  "global_forbidden": [
    "audit-face-except-wordmark-tag",
    "values-or-units-not-voice-tabular-500",
    "tracked-caps-on-product-surface",
    "gold-as-control-or-card-trim",
    "shadow-except-tier1-toast-launcher",
    "selection-as-ink-fill",
    "raw-hex-or-px-literal-in-component",
    "em-dash-in-user-facing-prose",
    "anonymous-string"
  ],
  "components": [
