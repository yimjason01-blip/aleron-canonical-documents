{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tokens.schema.json",
  "title": "Aleron design token source",
  "$defs": {
    "status": {
      "enum": ["draft", "provisional", "ratified", "retired"]
    },
    "token": {
      "type": "object",
      "required": ["$type", "$value", "css", "description", "status"],
      "properties": {
        "$type": {
          "enum": ["color", "fontFamily", "dimension", "cubicBezier", "duration", "shadow"]
        },
        "$value": {},
        "css": {
          "type": "string",
          "pattern": "^--[a-z0-9-]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {"$type": {"const": "color"}},
            "required": ["$type"]
          },
          "then": {
            "properties": {"$value": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"}}
          }
        },
        {
          "if": {
            "properties": {"$type": {"enum": ["dimension", "duration"]}},
            "required": ["$type"]
          },
          "then": {
            "properties": {"$value": {"type": "string", "minLength": 2}}
          }
        },
        {
          "if": {
            "properties": {"$type": {"enum": ["fontFamily", "cubicBezier", "shadow"]}},
            "required": ["$type"]
          },
          "then": {
            "properties": {"$value": {"type": "string", "minLength": 1}}
          }
        }
      ]
    },
    "group": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "anyOf": [
          {"$ref": "#/$defs/token"},
          {"$ref": "#/$defs/group"}
        ]
      }
    },
    "fontFace": {
      "type": "object",
      "required": ["family", "src", "weight", "style"],
      "properties": {
        "family": {"type": "string", "minLength": 1},
        "src": {"type": "string", "minLength": 1},
        "weight": {"type": "integer", "minimum": 100, "maximum": 900},
        "style": {"enum": ["normal", "italic"]}
      },
      "additionalProperties": false
    },
    "register": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string", "minLength": 1}
    }
  },
  "type": "object",
  "required": ["$schema", "name", "version", "updated", "description", "font_faces", "tokens", "registers"],
  "properties": {
    "$schema": {"const": "./schemas/tokens.schema.json"},
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "updated": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "description": {"type": "string", "minLength": 1},
    "font_faces": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/fontFace"}
    },
    "tokens": {
      "$ref": "#/$defs/group"
    },
    "registers": {
      "type": "object",
      "required": ["day", "flight-deck"],
      "properties": {
        "day": {"$ref": "#/$defs/register"},
        "flight-deck": {"$ref": "#/$defs/register"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
