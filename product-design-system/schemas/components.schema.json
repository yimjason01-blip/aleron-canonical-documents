{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "components.schema.json",
  "title": "Aleron component registry",
  "type": "object",
  "required": [
    "design_system",
    "version",
    "global_forbidden",
    "components"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "design_system": {
      "const": "aleron-md-product-ds"
    },
    "version": {
      "type": "string"
    },
    "updated": {
      "type": "string"
    },
    "status_note": {
      "type": "string"
    },
    "global_forbidden": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "status",
          "selector",
          "purpose",
          "registers",
          "required_tokens",
          "states",
          "forbidden",
          "reference",
          "implementation",
          "acceptance"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(core|domain|interaction)\\.[a-z0-9-]+$"
          },
          "category": {
            "enum": [
              "core",
              "domain",
              "interaction"
            ]
          },
          "status": {
            "enum": [
              "draft",
              "provisional",
              "ratified",
              "retired"
            ]
          },
          "selector": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "registers": {
            "type": "array",
            "items": {
              "enum": [
                "day",
                "flight-deck"
              ]
            }
          },
          "required_tokens": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "states": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forbidden": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reference": {
            "type": "string"
          },
          "implementation": {
            "type": "object"
          },
          "acceptance": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^T[1-7]$"
            }
          }
        }
      }
    }
  }
}
