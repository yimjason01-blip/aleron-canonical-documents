{
  "$schema": "./schemas/tokens.schema.json",
  "name": "Aleron MD Product Design System Tokens",
  "version": "0.4.0",
  "updated": "2026-07-16",
  "description": "Canonical primitive and semantic tokens used by the reference page and agent-built prototypes.",
  "font_faces": [
    {
      "family": "PolySans",
      "src": "fonts/PolySans-Slim.ttf",
      "weight": 300,
      "style": "normal"
    },
    {
      "family": "PolySans",
      "src": "fonts/PolySans-Neutral.ttf",
      "weight": 400,
      "style": "normal"
    },
    {
      "family": "PolySans",
      "src": "fonts/PolySans-NeutralItalic.ttf",
      "weight": 400,
      "style": "italic"
    },
    {
      "family": "PolySans",
      "src": "fonts/PolySans-Median.ttf",
      "weight": 500,
      "style": "normal"
    },
    {
      "family": "PolySans",
      "src": "fonts/PolySans-MedianItalic.ttf",
      "weight": 500,
      "style": "italic"
    },
    {
      "family": "PolySans",
      "src": "fonts/PolySans-Bulky.ttf",
      "weight": 700,
      "style": "normal"
    }
  ],
  "tokens": {
    "color": {
      "paper": {
        "$type": "color",
        "$value": "#FAF7F2",
        "css": "--paper",
        "description": "Day ground",
        "status": "ratified"
      },
      "ink": {
        "$type": "color",
        "$value": "#1D1B18",
        "css": "--ink",
        "description": "Day text and primary control",
        "status": "ratified"
      },
      "cream": {
        "$type": "color",
        "$value": "#F5F1E8",
        "css": "--cream",
        "description": "Night text",
        "status": "ratified"
      },
      "graphite": {
        "$type": "color",
        "$value": "#15171C",
        "css": "--graphite",
        "description": "Dark weave",
        "status": "ratified"
      },
      "gunmetal": {
        "$type": "color",
        "$value": "#333E48",
        "css": "--gunmetal",
        "description": "Elevated dark surface",
        "status": "ratified"
      },
      "steel": {
        "$type": "color",
        "$value": "#46555F",
        "css": "--steel",
        "description": "Light weave",
        "status": "ratified"
      },
      "navy": {
        "$type": "color",
        "$value": "#252B3D",
        "css": "--navy",
        "description": "Flight-deck ground",
        "status": "ratified"
      },
      "slate": {
        "$type": "color",
        "$value": "#5A6378",
        "css": "--slate",
        "description": "Day labels and baseline",
        "status": "ratified"
      },
      "gold": {
        "$type": "color",
        "$value": "#C9A14E",
        "css": "--gold",
        "description": "Forward signal, never a control",
        "status": "ratified"
      },
      "litGold": {
        "$type": "color",
        "$value": "#EACB7F",
        "css": "--lit-gold",
        "description": "Advisory on dark",
        "status": "ratified"
      },
      "textGold": {
        "$type": "color",
        "$value": "#8A6A2F",
        "css": "--text-gold",
        "description": "Advisory text on light",
        "status": "ratified"
      },
      "gold800": {
        "$type": "color",
        "$value": "#655127",
        "css": "--gold-800",
        "description": "Advisory text on inset",
        "status": "ratified"
      },
      "ember": {
        "$type": "color",
        "$value": "#A4452C",
        "css": "--ember",
        "description": "Hazard only",
        "status": "ratified"
      },
      "unmodeled": {
        "$type": "color",
        "$value": "#4A6FA5",
        "css": "--signal-unmodeled",
        "description": "Unmodeled window",
        "status": "provisional"
      },
      "dayTertiary": {
        "$type": "color",
        "$value": "#6E6A63",
        "css": "--day-text-tertiary",
        "description": "Lowest legal reading gray on paper",
        "status": "ratified"
      },
      "dayCard": {
        "$type": "color",
        "$value": "#FFFFFF",
        "css": "--day-surface-card",
        "description": "Day Tier 1 surface",
        "status": "ratified"
      },
      "dayInset": {
        "$type": "color",
        "$value": "#F1EDE6",
        "css": "--day-surface-inset",
        "description": "Day inset surface",
        "status": "ratified"
      },
      "nightInset": {
        "$type": "color",
        "$value": "#20253A",
        "css": "--night-surface-inset",
        "description": "Flight-deck inset surface",
        "status": "ratified"
      },
      "nightSunken": {
        "$type": "color",
        "$value": "#1C2030",
        "css": "--night-surface-sunken",
        "description": "Flight-deck sunken surface",
        "status": "ratified"
      }
    },
    "font": {
      "voice": {
        "$type": "fontFamily",
        "$value": "'PolySans', 'Hanken Grotesk', -apple-system, BlinkMacSystemFont, sans-serif",
        "css": "--voice",
        "description": "Product voice family",
        "status": "ratified"
      },
      "audit": {
        "$type": "fontFamily",
        "$value": "'Space Mono', ui-monospace, Menlo, monospace",
        "css": "--audit",
        "description": "Wordmark tag only",
        "status": "ratified"
      }
    },
    "size": {
      "display": {
        "$type": "dimension",
        "$value": "clamp(32px, 4vw, 48px)",
        "css": "--size-display",
        "description": "Display size",
        "status": "ratified"
      },
      "h1": {
        "$type": "dimension",
        "$value": "36px",
        "css": "--size-h1",
        "description": "Heading 1",
        "status": "ratified"
      },
      "h2": {
        "$type": "dimension",
        "$value": "26px",
        "css": "--size-h2",
        "description": "Heading 2",
        "status": "ratified"
      },
      "h3": {
        "$type": "dimension",
        "$value": "19px",
        "css": "--size-h3",
        "description": "Heading 3",
        "status": "ratified"
      },
      "lede": {
        "$type": "dimension",
        "$value": "18px",
        "css": "--size-lede",
        "description": "Lead text",
        "status": "ratified"
      },
      "text": {
        "$type": "dimension",
        "$value": "15.5px",
        "css": "--size-text",
        "description": "Body text",
        "status": "ratified"
      },
      "small": {
        "$type": "dimension",
        "$value": "13px",
        "css": "--size-small",
        "description": "Small text",
        "status": "ratified"
      },
      "audit": {
        "$type": "dimension",
        "$value": "11.5px",
        "css": "--size-audit",
        "description": "Tabular audit text",
        "status": "ratified"
      },
      "caption": {
        "$type": "dimension",
        "$value": "10.5px",
        "css": "--size-caption",
        "description": "Functional floor",
        "status": "ratified"
      }
    },
    "space": {
      "2xs": {
        "$type": "dimension",
        "$value": "4px",
        "css": "--s-2xs",
        "description": "4 px grid unit",
        "status": "ratified"
      },
      "xs": {
        "$type": "dimension",
        "$value": "8px",
        "css": "--s-xs",
        "description": "Spacing step",
        "status": "ratified"
      },
      "sm": {
        "$type": "dimension",
        "$value": "12px",
        "css": "--s-sm",
        "description": "Spacing step",
        "status": "ratified"
      },
      "md": {
        "$type": "dimension",
        "$value": "16px",
        "css": "--s-md",
        "description": "Spacing step",
        "status": "ratified"
      },
      "lg": {
        "$type": "dimension",
        "$value": "24px",
        "css": "--s-lg",
        "description": "Spacing step",
        "status": "ratified"
      },
      "xl": {
        "$type": "dimension",
        "$value": "32px",
        "css": "--s-xl",
        "description": "Spacing step",
        "status": "ratified"
      },
      "2xl": {
        "$type": "dimension",
        "$value": "48px",
        "css": "--s-2xl",
        "description": "Spacing step",
        "status": "ratified"
      },
      "3xl": {
        "$type": "dimension",
        "$value": "64px",
        "css": "--s-3xl",
        "description": "Spacing step",
        "status": "ratified"
      }
    },
    "air": {
      "row": {
        "$type": "dimension",
        "$value": "9px",
        "css": "--air-row",
        "description": "Within a group",
        "status": "provisional"
      },
      "group": {
        "$type": "dimension",
        "$value": "26px",
        "css": "--air-group",
        "description": "Into a new group",
        "status": "provisional"
      },
      "tier": {
        "$type": "dimension",
        "$value": "20px",
        "css": "--air-tier",
        "description": "Between sibling blocks",
        "status": "provisional"
      },
      "section": {
        "$type": "dimension",
        "$value": "44px",
        "css": "--air-section",
        "description": "Into a new section",
        "status": "provisional"
      }
    },
    "layout": {
      "nav": {
        "$type": "dimension",
        "$value": "200px",
        "css": "--nav-w",
        "description": "Reference navigation width",
        "status": "ratified"
      },
      "pageMax": {
        "$type": "dimension",
        "$value": "1240px",
        "css": "--page-max",
        "description": "Reference content maximum",
        "status": "ratified"
      }
    },
    "radius": {
      "panel": {
        "$type": "dimension",
        "$value": "18px",
        "css": "--radius-panel",
        "description": "Panel",
        "status": "ratified"
      },
      "tier1": {
        "$type": "dimension",
        "$value": "16px",
        "css": "--radius-tier1",
        "description": "Elevated card",
        "status": "ratified"
      },
      "tier2": {
        "$type": "dimension",
        "$value": "12px",
        "css": "--radius-tier2",
        "description": "Inset card",
        "status": "ratified"
      },
      "control": {
        "$type": "dimension",
        "$value": "10px",
        "css": "--radius-control",
        "description": "Control",
        "status": "ratified"
      },
      "tile": {
        "$type": "dimension",
        "$value": "4px",
        "css": "--radius-tile",
        "description": "Hazard and compact tile",
        "status": "ratified"
      }
    },
    "line": {
      "thin": {
        "$type": "dimension",
        "$value": "1px",
        "css": "--line-thin",
        "description": "Hairline",
        "status": "ratified"
      },
      "focus": {
        "$type": "dimension",
        "$value": "2px",
        "css": "--line-focus",
        "description": "Focus ring",
        "status": "ratified"
      },
      "signal": {
        "$type": "dimension",
        "$value": "3px",
        "css": "--line-signal",
        "description": "Gold signal bar",
        "status": "ratified"
      }
    },
    "control": {
      "minHeight": {
        "$type": "dimension",
        "$value": "44px",
        "css": "--control-min-h",
        "description": "Minimum mobile target",
        "status": "ratified"
      }
    },
    "motion": {
      "ease": {
        "$type": "cubicBezier",
        "$value": "cubic-bezier(0.4,0,0.2,1)",
        "css": "--ease",
        "description": "Default easing",
        "status": "ratified"
      },
      "fast": {
        "$type": "duration",
        "$value": "150ms",
        "css": "--dur-fast",
        "description": "Fast transition",
        "status": "ratified"
      },
      "base": {
        "$type": "duration",
        "$value": "240ms",
        "css": "--dur-base",
        "description": "Base transition",
        "status": "ratified"
      },
      "slow": {
        "$type": "duration",
        "$value": "400ms",
        "css": "--dur-slow",
        "description": "Slow transition",
        "status": "ratified"
      }
    },
    "shadow": {
      "tier1": {
        "$type": "shadow",
        "$value": "0 12px 36px rgba(29,27,24,0.09)",
        "css": "--day-shadow-tier1",
        "description": "Day Tier 1 shadow",
        "status": "ratified"
      }
    }
  },
  "registers": {
    "day": {
      "ground": "{color.paper}",
      "text-primary": "{color.ink}",
      "text-secondary": "{color.slate}",
      "text-tertiary": "{color.dayTertiary}",
      "surface-card": "{color.dayCard}",
      "surface-inset": "{color.dayInset}",
      "surface-sunken": "{color.cream}",
      "surface-selected": "{color.dayInset}",
      "surface-tier1": "{color.dayCard}",
      "surface-tier2": "{color.dayInset}",
      "border-subtle": "rgba(29,27,24,0.10)",
      "border-base": "rgba(29,27,24,0.18)",
      "border-strong": "rgba(29,27,24,0.35)",
      "hairline": "rgba(29,27,24,0.07)",
      "signal-forward": "{color.gold}",
      "signal-advisory": "{color.textGold}",
      "signal-hazard": "{color.ember}",
      "signal-baseline": "{color.slate}",
      "control-primary-bg": "{color.ink}",
      "control-primary-fg": "{color.cream}",
      "control-primary-hover-bg": "#000000",
      "control-disabled-bg": "{color.dayInset}",
      "control-disabled-fg": "rgba(29,27,24,0.38)",
      "shadow-tier1": "{shadow.tier1}"
    },
    "flight-deck": {
      "ground": "{color.navy}",
      "text-primary": "{color.cream}",
      "text-secondary": "rgba(245,241,232,0.68)",
      "text-tertiary": "rgba(245,241,232,0.55)",
      "surface-card": "{color.gunmetal}",
      "surface-inset": "{color.nightInset}",
      "surface-sunken": "{color.nightSunken}",
      "surface-selected": "{color.gunmetal}",
      "surface-tier1": "{color.gunmetal}",
      "surface-tier2": "{color.nightInset}",
      "border-subtle": "rgba(245,241,232,0.08)",
      "border-base": "rgba(245,241,232,0.14)",
      "border-strong": "rgba(245,241,232,0.25)",
      "hairline": "rgba(245,241,232,0.09)",
      "signal-forward": "{color.gold}",
      "signal-advisory": "{color.litGold}",
      "signal-hazard": "{color.ember}",
      "signal-baseline": "rgba(245,241,232,0.68)",
      "control-primary-bg": "{color.cream}",
      "control-primary-fg": "{color.ink}",
      "control-primary-hover-bg": "#FFFFFF",
      "control-disabled-bg": "rgba(245,241,232,0.12)",
      "control-disabled-fg": "rgba(245,241,232,0.30)",
      "shadow-tier1": "0 0 0 1px rgba(245,241,232,0.10)"
    }
  }
}
